%% -*- mode: erlang -*-
%% rebar3 configuration for hecate_embed

{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

%% No deps. The optional HTTP service form (hecate_embed_server) uses inets
%% httpd, which is already an OTP application this app depends on (the ollama
%% and remote backends use httpc), so the service adds no dependency and no web
%% framework to version-match against consumers.
{deps, []}.

%% NOTE: rustler / rebar3_cargo intentionally NOT declared as deps.
%% See `hecate-vector/rebar.config' for the long explanation —
%% short version: rustler 0.34 pulls in mix-only transitives and
%% rebar3 can't build them. NIF Erlang side compiles fine without
%% rustler on the BEAM code path; build the .so via
%% `scripts/build-nif.sh' which invokes cargo directly.
{project_plugins, [
    rebar3_hex,
    rebar3_ex_doc
]}.

{shell, [
    {apps, [hecate_embed]}
]}.

{hex, [
    {name, hecate_embed},
    {doc, #{provider => ex_doc}},
    {licenses, ["Apache-2.0"]},
    {links, #{
        <<"Codeberg">> => <<"https://codeberg.org/hecate-social/hecate-embed">>
    }},
    {description, "Local multilingual sentence embeddings for Hecate (Rustler NIF over fastembed-rs)"}
]}.

{ex_doc, [
    {source_url, <<"https://codeberg.org/hecate-social/hecate-embed">>},
    {extras, ["README.md", "CHANGELOG.md", "LICENSE", "guides/getting_started.md"]},
    {main, "README.md"}
]}.

{profiles, [
    {lint, [
        {plugins, [{rebar3_lint, "5.0.4"}]}
    ]}
]}.

{elvis, [
    {rulesets, #{
        macula_min => [
            {elvis_style, no_deep_nesting, #{level => 2}},
            {elvis_style, no_nested_try_catch, #{}},
            {elvis_style, no_if_expression, #{}}
        ]
    }},
    {config, [ #{files => ["src/**/*.erl"], ruleset => macula_min} ]}
]}.
