%% -*- mode: erlang -*-
%% rebar3 configuration for hecate_embed

{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    {rustler, "0.34.0"}
]}.

{project_plugins, [
    rebar3_cargo,
    rebar3_hex,
    rebar3_ex_doc
]}.

{provider_hooks, [
    {pre, [
        {compile, {cargo, build}}
    ]},
    {post, [
        {clean, {cargo, clean}}
    ]}
]}.

{cargo_opts, [
    {src_dir, "native/hecate_embed_nif"}
]}.

{shell, [
    {apps, [hecate_embed]}
]}.

{hex, [
    {name, hecate_embed},
    {doc, #{provider => ex_doc}},
    {licenses, ["Apache-2.0"]},
    {links, #{
        <<"Codeberg">> => <<"https://codeberg.org/hecate-social/hecate-embed">>
    }},
    {description, "Local multilingual sentence embeddings for Hecate (Rustler NIF over fastembed-rs)"}
]}.

{ex_doc, [
    {source_url, <<"https://codeberg.org/hecate-social/hecate-embed">>},
    {extras, ["README.md", "CHANGELOG.md", "LICENSE", "guides/getting_started.md"]},
    {main, "README.md"}
]}.
